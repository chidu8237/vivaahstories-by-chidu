# ─── Site (required for auth redirects) ─────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Supabase Dashboard checklist ───────────────────────────────────────────
# 1. Run supabase/schema.sql in SQL Editor
# 2. Set admin: update profiles set role='admin' where email='your@email.com'
# 3. Auth → URL Configuration → Site URL + Redirect URLs (see SUPABASE_SETUP.md)
# 4. Auth → SMTP Settings → Custom SMTP (Resend/SendGrid) for reliable emails
# 5. Storage → verify "gallery" bucket is public

# ─── Optional: Cloudinary (legacy/alternate CDN) ────────────────────────────
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
